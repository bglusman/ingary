{
  "run_id": "toy-static-actions-v1",
  "feature": "instrumentation_probe",
  "backend": "toy",
  "simulated_prompt": "Pretend to inspect the repo and report what bakeoff harness data can be captured. Do not edit files.",
  "expected": {
    "actions": 4,
    "commands": 3,
    "failed_actions": 0,
    "git_status_changed": false,
    "git_head_changed": false,
    "git_commits_added": 0
  },
  "actions": [
    {
      "id": "repo_state",
      "kind": "command",
      "cmd": ["git", "status", "--short", "--branch"]
    },
    {
      "id": "bakeoff_doc_mentions",
      "kind": "command",
      "cmd": ["rg", "-n", "bakeoff|scoring|rubric|held-out", "docs/prototype-bakeoff-plan.md"]
    },
    {
      "id": "stable_latency_probe",
      "kind": "command",
      "cmd": ["python3", "-c", "import time; time.sleep(0.05); print('latency_probe=ok')"]
    },
    {
      "id": "simulated_agent_summary",
      "kind": "note",
      "output": "The run inspected repository status, searched the bakeoff plan, performed a deterministic latency probe, and made no intentional code changes."
    }
  ]
}
